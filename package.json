{
  "name": "plugin_name",
  "version": "1.2.3",
  "description": "A WordPress boilerplate plugin using vue.js",
  "main": "index.js",
  "scripts": {
    "dev": "node src/env/development_mode.js && vite",
    "watch": "npm run dev",
    "build": "node src/env/production_mode.js && vite build",
    "build:zip": "npm run package",
    "production": "npm run build",
    "package": "npm run build && mkdir -p builds && rm -f builds/buy-me-coffee.zip && zip -r builds/buy-me-coffee.zip assets buy-me-coffee.php includes index.php languages license.txt readme.txt"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@element-plus/icons-vue": "^2.0.9",
    "@fontsource/inter": "^5.2.8",
    "@wordpress/hooks": "^3.1.1",
    "chart.js": "^4.4.0",
    "clipboard": "^2.0.11",
    "element-plus": "^2.13.7",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "lucide-vue-next": "^1.0.0",
    "nanoid": "^5.1.9",
    "vue": "^3.2.39",
    "vue-router": "^4.1.5"
  },
  "devDependencies": {
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.14.7",
    "@babel/preset-react": "^7.22.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "^3.2.39",
    "autoprefixer": "^10.4.20",
    "babel-eslint": "^10.1.0",
    "babel-plugin-component": "^1.1.1",
    "babel-plugin-import": "^1.13.3",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.10",
    "react": "^18.2.0",
    "resolve-url-loader": "^5.0.0",
    "rollup-plugin-copy": "^3.4.0",
    "sass": "^1.35.1",
    "sass-loader": "^10",
    "tailwindcss": "^3.4.14",
    "unplugin-auto-import": "^0.11.5",
    "unplugin-vue-components": "^0.22.12",
    "vite": "^8.0.10",
    "vite-plugin-live-reload": "^2.1.0",
    "vite-plugin-static-copy": "^4.1.0",
    "vue-cli-plugin-tailwind": "~3.0.0",
    "vue-loader": "^16.3.0"
  }
}
